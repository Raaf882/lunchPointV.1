# انسخ هذا الملف باسم .env داخل مجلد backend/ وعدّل القيم
PORT=3000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=غيّر_هذه_الكلمة

# البريد الذي تصله تنبيهات النماذج الجديدة (اكتشف شغفك / تواصل معنا / تسجيل فعالية)
ADMIN_NOTIFICATION_EMAIL=admin@example.com

# إعدادات SMTP لإرسال بريد التنبيهات — بدون هذه القيم الأربع تعمل التنبيهات داخل اللوحة بشكل طبيعي فقط، ويُتخطّى إرسال البريد بصمت (تُسجَّل رسالة في console)
# مثال Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER=بريدك@gmail.com, SMTP_PASS=App Password (وليس كلمة مرور حسابك العادية)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
